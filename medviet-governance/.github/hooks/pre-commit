#!/bin/bash
# Pre-commit hook: chạy security checks trước khi commit

set -e

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
LAB_DIR="$ROOT/medviet-governance"
if [ ! -d "$LAB_DIR/src" ] && [ -d "$ROOT/src" ]; then
    LAB_DIR="$ROOT"
fi

echo "Running security checks..."

# 1. git-secrets scan
if command -v git-secrets >/dev/null 2>&1; then
    git secrets --pre_commit_hook -- "$@"
else
    secret_pattern='(CCCD[:[:space:]]+[0-9]{12}|cccd[:[:space:]]+[0-9]{12}|password[[:space:]]*=[[:space:]]*["'\''][^"'\'']+["'\'']|secret_key[[:space:]]*=[[:space:]]*["'\''][^"'\'']+["'\'']|AWS_SECRET_KEY[[:space:]]*=)'

    while IFS= read -r file; do
        [ -z "$file" ] && continue
        if git show ":$file" 2>/dev/null | grep -E "$secret_pattern" >/dev/null; then
            echo "Potential secret found in staged file: $file"
            exit 1
        fi
    done <<EOF
$(git diff --cached --name-only --diff-filter=ACM)
EOF
fi

# 2. Bandit SAST scan
echo "Running Bandit SAST..."
if command -v bandit >/dev/null 2>&1; then
    (cd "$LAB_DIR" && bandit -r src/ -ll -q)
else
    echo "bandit not installed; skipping SAST scan."
fi

# 3. pip-audit dependency check
echo "Checking dependencies for CVEs..."
if command -v pip-audit >/dev/null 2>&1; then
    if [ -f "$LAB_DIR/requirements.txt" ]; then
        (cd "$LAB_DIR" && pip-audit -r requirements.txt --desc on)
    else
        pip-audit --desc on
    fi
else
    echo "pip-audit not installed; skipping dependency scan."
fi

echo "All security checks passed."
exit 0
